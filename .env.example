# =============================================================================
# CFO Family Finance App — Environment Variables
# Copy file này thành .env.local và điền giá trị thực
# =============================================================================

# ---- DATABASE (Supabase) ----
# Lấy từ: Supabase Dashboard → Settings → Database → Connection string
# "Transaction pooler" cho DATABASE_URL (hỗ trợ serverless)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# "Session pooler" hoặc Direct cho DIRECT_URL (dùng cho migrations)
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ---- AUTH (NextAuth.js) ----
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-at-least-32-chars"

# Google OAuth (tạo tại console.cloud.google.com)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ---- SUPABASE (cho Realtime & Storage) ----
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ---- AI / OCR ----
# Google Vision API
GOOGLE_VISION_API_KEY="your-google-vision-api-key"

# Hoặc OpenAI (cho GPT-4 Vision)
# OPENAI_API_KEY="sk-..."

# ---- NOTIFICATIONS ----
# Zalo Official Account
ZALO_OA_TOKEN="your-zalo-oa-token"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"

# Web Push (tạo bằng: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_EMAIL="mailto:admin@yourapp.com"

# ---- STOCK DATA (cho Investment portfolio) ----
# VNStock API (nếu có)
VNSTOCK_API_KEY=""

# ---- APP CONFIG ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="CFO Family"
NODE_ENV="development"
